# Claude Code local settings
.claude/

# Azure credentials and local config (both v1 Azure/ and v2 Azure-Native-Build/)
Azure/connections.json
Azure/config.json
Azure-Native-Build/connections.json
Azure-Native-Build/config.json

# Build output
Azure/build/
Azure-Native-Build/build/
*.pak

# Runtime logs — must not be committed; stale files block container user writes
Azure/logs/
Azure-Native-Build/logs/

# Duplicate conf (generated by mp-build)
Azure/app/conf/
Azure-Native-Build/app/conf/

# Debug/scratch files — logs are machine-local and must never be tracked:
# the server workflow starts with `git reset --hard origin/main`, which
# reverts a tracked build.log to the stale committed copy, silently wiping
# fresh build output. README, scrub.py, and redacted verify JSONs stay tracked.
debug/*.log


# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/

# Large binaries — transfer out-of-band, not via git
*.tar
*.zip
aria-wheels/
wheels/
Images/

# IDE
.vscode/
.idea/
*.swp
